# Rainz SkyCam Raspberry Pi config
# Copy to .env and fill in real values. Do NOT commit .env.

RAINZ_SKYCAM_UPLOAD_URL=https://ohwtbkudpkfbakynikyj.functions.supabase.co/upload-skycam-observation
RAINZ_SKYCAM_STATION_CODE=CPH-BISPEBJERG-001

# Generate a long random secret, then update skycam_stations.upload_key_hash
# with the SHA-256 hex of (secret + ":" + SKYCAM_UPLOAD_SECRET_PEPPER).
# See docs/skycam-setup.md.
RAINZ_SKYCAM_UPLOAD_KEY=replace-with-long-random-secret

RAINZ_SKYCAM_INTERVAL_MINUTES=5
RAINZ_SKYCAM_FIRMWARE=rainz-skycam-pi/1.0.0
